	<style>
		@keyframes piscar-icone {
		  0%   { transform: scale(1); }
		  50%  { transform: scale(1.4); }
		  100% { transform: scale(1); }
		}

		.piscar-icone {
		  animation: piscar-icone 0.6s ease-in-out;
		}
	</style>
	<script>
	document.addEventListener('DOMContentLoaded', function () {
	  const link = document.querySelector('a.stretched-link[href="#sic-presencial"]');

	  if (!link) {
		console.warn('Link para #sic-presencial não encontrado');
		return;
	  }

	  link.addEventListener('click', function (e) {
		e.preventDefault();

		const target = document.querySelector('#sic-presencial');
		if (!target) {
		  console.warn('#sic-presencial não encontrado');
		  return;
		}

		// Scroll suave
		target.scrollIntoView({ behavior: 'smooth', block: 'start' });

		// Aguarda scroll e aplica animação
		setTimeout(function () {
		  const icons = target.querySelectorAll('i');
		  if (icons.length === 0) {
			console.warn('Nenhum <i> encontrado dentro de #sic-presencial');
			return;
		  }

		  icons.forEach(function (icon) {
			icon.classList.add('piscar-icone');
		  });

		  setTimeout(function () {
			icons.forEach(function (icon) {
			  icon.classList.remove('piscar-icone');
			});
		  }, 1000); // Tempo da animação + pequena margem
		}, 600); // Tempo do scroll
	  });
	});
	</script>
