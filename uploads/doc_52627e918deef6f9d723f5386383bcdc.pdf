	<script>
		document.addEventListener('DOMContentLoaded', function() {

			/**
			 * =================================================================
			 * LÓGICA FINAL PARA ATALHOS DE TECLADO (Acessibilidade)
			 * =================================================================
			 */
			
			// ATENÇÃO: Verifique e corrija os URLs abaixo para que correspondam
			// aos links corretos do seu site.
			const atalhos = {
				'M': 'https://camaraemas.pb.gov.br/',                  // Menu Principal
				'N': 'https://camaraemas.pb.gov.br/informativos/noticias',                // Notícias
				'L': '',        // Licitações
				'F': '',    // Portal da Transparência
				'O': '',               // Ouvidoria
				'S': '',                    // Portal SIC
				'G': 'https://camaraemas.pb.gov.br/consulta/glossario',               // Glossário
				'W': 'http://mail.google.com/a/camaraemas.pb.gov.br'                  // Webmail
			};

			document.addEventListener('keydown', function(event) {

				// Verifica se as teclas ALT e SHIFT foram pressionadas juntas.
				if (event.altKey && event.shiftKey) {
					
					// Pega a tecla pressionada.
					const teclaPressionada = event.key.toUpperCase();

					// AJUSTE: Ignora teclas especiais como 'SHIFT', 'ALT', 'CONTROL', etc.
					// Processa apenas se a tecla for um único caractere (uma letra).
					if (teclaPressionada.length === 1) {

						// Procura a URL correspondente no mapa de atalhos.
						const urlDestino = atalhos[teclaPressionada];

						if (urlDestino) {
							// Impede a ação padrão do navegador.
							event.preventDefault();
							
							// REDIRECIONAMENTO ATIVADO: Leva o usuário para a URL.
							window.location.href = urlDestino;
						}
					}
				}
			});

		});
		</script>

